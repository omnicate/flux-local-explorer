load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "v1alpha1",
    srcs = [
        "processing.go",
        "types.go",
    ],
    embedsrcs = [
        "platform.example.com_exampleapps.yaml",
        "templates/job_worker.template.yaml",
        "templates/postgres_secret_env_patch.template.yaml",
        "templates/web_worker.template.yaml",
    ],
    importpath = "github.com/omnicate/flx/lib/kustomize/functions/examples/fn-framework-application/pkg/exampleapp/v1alpha1",
    visibility = ["//visibility:public"],
    deps = [
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_kube_openapi//pkg/validation/spec",
        "@io_k8s_sigs_kustomize_kyaml//errors",
        "@io_k8s_sigs_kustomize_kyaml//fn/framework",
        "@io_k8s_sigs_kustomize_kyaml//fn/framework/parser",
        "@io_k8s_sigs_kustomize_kyaml//resid",
        "@io_k8s_sigs_kustomize_kyaml//yaml",
    ],
)

go_test(
    name = "v1alpha1_test",
    srcs = ["example_app_test.go"],
    data = glob(["testdata/**"]),
    deps = [
        "@io_k8s_sigs_kustomize_functions_examples_fn_framework_application//pkg/dispatcher:go_default_library",
        "@io_k8s_sigs_kustomize_kyaml//fn/framework/frameworktestutil",
    ],
)
