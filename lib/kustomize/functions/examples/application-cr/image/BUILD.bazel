load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "image_lib",
    srcs = ["main.go"],
    importpath = "github.com/omnicate/flx/lib/kustomize/functions/examples/application-cr/image",
    visibility = ["//visibility:private"],
    deps = [
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/runtime/schema",
        "@io_k8s_sigs_application//api/v1beta1:go_default_library",
        "@io_k8s_sigs_kustomize_kyaml//kio",
        "@io_k8s_sigs_kustomize_kyaml//yaml",
        "@io_k8s_sigs_yaml//:yaml",
    ],
)

go_binary(
    name = "image",
    embed = [":image_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "image_test",
    srcs = ["main_test.go"],
    embed = [":image_lib"],
)
